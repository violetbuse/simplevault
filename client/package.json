{
  "name": "simplevault",
  "version": "0.5.11",
  "description": "Client library for the SimpleVault encryption API",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "test:contract": "node --test test/contract.mjs",
    "test:contract:rust": "node test/run-with-rust-server.mjs",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "encryption",
    "vault",
    "aes-gcm",
    "simplevault"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/violetbuse/simplevault.git"
  },
  "homepage": "https://simplevault.viowet.com",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0"
  }
}
