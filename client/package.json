{
  "name": "simplevault",
  "version": "0.5.0",
  "description": "Client library and dev server for SimpleVault encryption API",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "simplevault": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "test:contract": "node --test test/contract.mjs",
    "test:contract:dev": "node test/run-with-dev-server.mjs",
    "test:contract:rust": "node test/run-with-rust-server.mjs",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "encryption",
    "vault",
    "aes-gcm",
    "simplevault"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/violetbuse/simplevault.git"
  },
  "homepage": "https://simplevault.viowet.com",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "express": "^4.21.0",
    "pg": "^8.16.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.0",
    "@types/pg": "^8.15.5",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}